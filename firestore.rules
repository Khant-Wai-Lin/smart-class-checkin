rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Sessions are typically created by instructors/admins.
    match /sessions/{sessionId} {
      allow read: if signedIn();
      allow write: if false; // MVP: lock down by default
    }

    // Attendance documents keyed like: {sessionId}_{uid}
    match /attendance/{docId} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow delete: if false;
    }
  }
}
